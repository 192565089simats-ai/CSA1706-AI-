from queue import PriorityQueue

# Goal State
goal = [[1,2,3],
        [4,5,6],
        [7,8,0]]

# Node class stores puzzle state and level (g(n))
class Node:

    def __init__(self, data, level):
        self.data = data      # Current puzzle state
        self.level = level    # Number of moves from start

    # Find the position of the blank tile (0)
    def find(self, x):
        for i in range(3):
            for j in range(3):
                if self.data[i][j] == x:
                    return i, j

    # Generate all possible child states
    def generate_child(self):

        # Find blank tile
        x, y = self.find(0)

        # Possible moves: Up, Down, Left, Right
        moves = [(x-1,y), (x+1,y), (x,y-1), (x,y+1)]

        children = []

        for i, j in moves:

            # Check valid move
            if 0 <= i < 3 and 0 <= j < 3:

                # Copy current state
                temp = [row[:] for row in self.data]

                # Swap blank with adjacent tile
                temp[x][y], temp[i][j] = temp[i][j], temp[x][y]

                # Store child node with increased level
                children.append(Node(temp, self.level + 1))

        return children


# Heuristic Function
# Counts the number of misplaced tiles
def heuristic(state):

    count = 0

    for i in range(3):
        for j in range(3):

            if state[i][j] != 0 and state[i][j] != goal[i][j]:
                count += 1

    return count


# Evaluation Function
# f(n) = g(n) + h(n)
def f(node):
    return node.level + heuristic(node.data)


# Initial State
start = [[5,4,0],
         [6,1,8],
         [7,3,2]]

# Create Priority Queue
pq = PriorityQueue()

# Create Root Node
root = Node(start,0)

# Insert root node into queue
pq.put((f(root), id(root), root))

# Store visited states
visited = []

# Continue until queue becomes empty
while not pq.empty():

    # Remove node with minimum f(n)
    current = pq.get()[2]

    # Display current puzzle state
    for row in current.data:
        print(row)
    print()

    # Check Goal State
    if heuristic(current.data) == 0:
        print("Goal Reached")
        break

    # Mark current state as visited
    visited.append(current.data)

    # Generate child states
    for child in current.generate_child():

        # Add only unvisited states
        if child.data not in visited:

            # Insert child into Priority Queue
            pq.put((f(child), id(child), child))
